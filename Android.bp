android_app_import {
    name: "Messaging",
    product_specific: true,

    apk: "prebuilt/Messaging.apk",
    preprocessed: true,

    optional_uses_libs: ["androidx.window.extensions", "androidx.window.sidecar"],

    required: [
        "whitelist_com.android.messaging.xml"
    ]
}

prebuilt_etc {
    name: "whitelist_com.android.messaging.xml",
    product_specific: true,
    sub_dir: "sysconfig",
    src: "whitelist_com.android.messaging.xml",
    filename_from_src: true,
}
